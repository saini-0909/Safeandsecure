<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <title>Safe and Secure Trading</title>
</head>
<body>
    <header>
        <nav>
            <div class="logo">Safe and Secure</div>
            <ul>
                <li><a href="#services">Services</a></li>
                <li><a href="#features">Features</a></li>
                <li><a href="#accounts">Account Types</a></li>
                <li><a href="#testimonials">Testimonials</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>
    <section class="hero">
        <h1>Welcome to the Future of Trading</h1>
        <p>Trade Forex, Crypto, and more with ease.</p>
        <a href="#" class="cta-button">Start Trading</a>
        <a href="#" class="cta-button">Sign Up</a>
    </section>
    <section id="services">
        <h2>Our Services</h2>
        <ul>
            <li>Forex</li>
            <li>Crypto</li>
            <li>CFDs</li>
            <li>Indices</li>
            <li>Commodities</li>
        </ul>
    </section>
    <section id="features">
        <h2>Features</h2>
        <ul>
            <li>Security</li>
            <li>Leverage</li>
            <li>Support</li>
            <li>Speed</li>
        </ul>
    </section>
    <section id="accounts">
        <h2>Account Types</h2>
        <ul>
            <li>Beginner</li>
            <li>Professional</li>
            <li>VIP</li>
        </ul>
    </section>
    <section id="market-data">
        <h2>Live Market Data</h2>
        <div class="market-data-display">Data will be updated here...</div>
    </section>
    <section id="testimonials">
        <h2>Testimonials</h2>
        <p>"The best trading platform!" - User A</p>
        <p>"I made my first profit!" - User B</p>
    </section>
    <section id="faq">
        <h2>FAQs</h2>
        <p>Q: How do I start?</p>
        <p>A: Sign up and deposit funds.</p>
    </section>
    <section id="contact">
        <h2>Contact Us</h2>
        <form>
            <label for="name">Name:</label>
            <input type="text" id="name" name="name" required>
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" required>
            <button type="submit">Submit</button>
        </form>
    </section>
    <footer>
        <p>&copy; 2026 Safe and Secure Trading. All rights reserved.</p>
    </footer>
    <script src="script.js"></script>
</body>
</html>
